<configs>

  <!-- ============================================================
       EV_DailyWeeklyLootBoxes — Daily Loot Box
      Tier selector: common is always granted.
      Bonus rolls are independent add-ons:
        20% → Uncommon (quality food, better medicine, HP ammo)
      5% → Rare     (repair kits, steroids, skill magazine)
      Each tier pool uses count="all" so every item in the
      triggered tier is guaranteed to drop.
  ============================================================ -->

  <!-- Append all groups and the container in one block so
       forward references are resolved together. -->
  <append xpath="/lootcontainers">

    <!-- *** evDailyFoodSimple — one random simple food item
         Very basic canned goods: larger count (3–5)
         Decent canned meats/fish: medium count (2–4)
         Cooked foods:             smaller count (1–3) -->
    <lootgroup name="evDailyFoodSimple" count="1">
      <!-- very basic canned goods -->
      <item name="foodCanPeas"      count="3,5"/>
      <item name="foodCanSoup"      count="3,5"/>
      <item name="foodCanSham"      count="3,5"/>
      <item name="foodCanChicken"   count="3,5"/>
      <!-- decent canned goods -->
      <item name="foodCanChili"     count="2,4"/>
      <item name="foodCanBeef"      count="2,4"/>
      <item name="foodCanTuna"      count="2,4"/>
      <item name="foodCanPasta"     count="2,4"/>
      <!-- cooked foods -->
      <item name="foodCornBread"    count="1,3"/>
      <item name="foodGrilledMeat"  count="1,3"/>
      <item name="foodEggBoiled"    count="1,3"/>
      <item name="foodBakedPotato"  count="1,3"/>
    </lootgroup>

    <!-- *** evDailyDrinkSimple — one random simple drink
         Boiled water: medium count (2–4)
         Yucca juice:  medium count (1–3)
         Tea / beer:   smallest count (1–2) -->
    <lootgroup name="evDailyDrinkSimple" count="1">
      <item name="drinkJarBoiledWater"  count="2,4"/>
      <item name="drinkJarYuccaJuice"   count="1,3"/>
      <item name="drinkJarGoldenRodTea" count="1,2"/>
      <item name="drinkJarBeer"         count="1,2"/>
    </lootgroup>

    <!-- *** evDailyMedSimple — one random basic medical item
         Most basic (bandage, aloe):   larger count (3–5 / 2–4)
         Better bandage:               medium count (2–4)
         Drugs (vitamins, painkillers): smaller count (1–3) -->
    <lootgroup name="evDailyMedSimple" count="1">
      <!-- very basic -->
      <item name="medicalBandage"          count="3,5"/>
      <item name="medicalAloeCream"        count="2,4"/>
      <!-- standard first-aid -->
      <item name="medicalFirstAidBandage"  count="2,4"/>
      <!-- drugs -->
      <item name="drugVitamins"            count="1,3"/>
      <item name="drugPainkillers"         count="1,3"/>
    </lootgroup>

    <!-- *** evDailyCommonPool — always granted -->
    <lootgroup name="evDailyCommonPool" count="all">
      <item group="evDailyFoodSimple"/>
      <item group="evDailyDrinkSimple"/>
      <item group="evDailyMedSimple"/>
      <item name="ammo9mmBulletBall"   count="50,100"/>
    </lootgroup>

    <!-- *** evDailyUncommonPool — 20% tier -->
    <lootgroup name="evDailyUncommonPool" count="all">
      <item name="foodMeatStew"        count="1,2"/>
      <item name="medicalFirstAidKit"  count="1,2"/>
      <item name="ammo9mmBulletHP"     count="50,100"/>
    </lootgroup>

    <!-- *** evDailyRarePool — 5% tier -->
    <lootgroup name="evDailyRarePool" count="all">
      <item name="resourceRepairKit"      count="3,5"/>
      <item name="drugSteroids"           count="1,2"/>
      <item name="handgunsSkillMagazine"  count="2,3"/>
    </lootgroup>

    <!-- *** Tier selector: common is guaranteed, bonus tiers roll independently -->
    <lootgroup name="evDailyTierSelector" count="all">
      <item group="evDailyCommonPool"/>
      <item group="evDailyUncommonPool" prob="0.20" force_prob="true"/>
      <item group="evDailyRarePool"     prob="0.05" force_prob="true"/>
    </lootgroup>

    <!-- *** Loot container opened by evDailyLootBundle -->
    <lootcontainer name="evDailyLootBox"
                   count="1"
                   size="3,2"
                   sound_open="SupplyDrops/open_supply_crate"
                   sound_close="SupplyDrops/close_supply_crate"
                   loot_quality_template="qualBaseTemplate"
                   destroy_on_close="empty"
                   unique_item="true"
                   ignore_loot_abundance="true">
      <item group="evDailyTierSelector"/>
    </lootcontainer>

  </append>

</configs>
