<?xml version="1.0" encoding="UTF-8"?>
<config>

  <!--
    Re-categorize Project Z bundle items so they appear in the vanilla
    inventory crafting tabs (Ammo/Weapons and Tools/Traps) instead of the
    custom "Donate*" groups from Z_RareItems / Z_Master_Skills, which are
    not bound to any tab in the inventory crafting UI and therefore hide
    the recipes added by this mod.
  -->

  <!-- ===== Rare Ranged Weapons (Z_RareItems) ===== -->
  <set xpath="/items/item[@name='rareSniperRifleBundle']/property[@name='Group']/@value">Ammo/Weapons,Ranged Weapons</set>
  <set xpath="/items/item[@name='rareAutoShotgunBundle']/property[@name='Group']/@value">Ammo/Weapons,Ranged Weapons</set>
