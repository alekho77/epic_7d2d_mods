<?xml version="1.0" encoding="UTF-8"?>
<config>

  <!--
    Re-categorize Project Z Unique item modifiers (Z_Rare_Modifiers) so
    they appear in the vanilla inventory crafting tabs. By default they
    use Group="RareMods", which is not bound to any tab in the inventory
    crafting UI and therefore hides the direct recipes added by this mod.

    These modifiers are deterministic single objects (1 recipe = 1 mod),
    so they no longer require bundle wrappers — we craft them directly
    from Epic Bucks, exactly like the Repair Kit recipes.
  -->

  <!-- ===== Unique Gun Mods (Ammo/Weapons → Mods) ===== -->
  <set xpath="/item_modifiers/item_modifier[@name='modGunMagazineExtenderUnique']/property[@name='Group']/@value">Ammo/Weapons,Mods</set>
  <set xpath="/item_modifiers/item_modifier[@name='modGunDrumMagazineExtenderUnique']/property[@name='Group']/@value">Ammo/Weapons,Mods</set>
