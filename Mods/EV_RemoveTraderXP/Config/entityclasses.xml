<configs>
  <!-- Remove all XP gained from selling items to traders.
       Using -100 (-10000%) to guarantee zero result even when
       global XP bonus buffs (Grandpa's Elixir, Twitch buffs, etc.) are active. -->
  <append xpath="/entity_classes/entity_class[@name='playerMale']">
    <effect_group name="Remove Trader XP">
      <passive_effect name="PlayerExpGain" operation="perc_add" value="-100" tags="Selling"/>
    </effect_group>
  </append>
</configs>
