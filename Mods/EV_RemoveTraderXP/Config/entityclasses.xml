<configs>
  <!-- Remove all XP gained from selling items to traders.
       base_set 0 zeroes the base multiplier, so 0 * (1 + any perc_add) = 0.
       No negative XP possible, unaffected by XP bonus buffs. -->
  <append xpath="/entity_classes/entity_class[@name='playerMale']">
    <effect_group name="Remove Trader XP">
      <passive_effect name="PlayerExpGain" operation="base_set" value="0" tags="Selling"/>
    </effect_group>
  </append>
</configs>
