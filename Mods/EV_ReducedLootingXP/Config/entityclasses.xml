<configs>
  <!-- Reduce XP gained from opening untouched loot containers to ~20% of vanilla.
       Uses perc_add -0.799 (not -0.8) because -0.8 cannot be represented exactly in
       IEEE 754 single-precision float: the nearest float32 is ~-0.800000012, giving
       an effective multiplier of ~0.199999988 instead of 0.2. This causes truncation
       to drop exactly-divisible thresholds by 1 (e.g. GS10->1, GS25->4, GS50->9).
       Using -0.799 gives effective multiplier ~0.201, safely above 0.2, so truncation
       produces the expected results: GS5->1, GS10->2, GS27->5, GS50->10.
       base_set is NOT used here: base_set replaces _base_value with a literal number,
       which would give flat XP (e.g. base_set 5 = always 5 XP regardless of GS).
       Loot quality, search speed, loot tables, and Lucky Looter perk are unaffected.
       Note: large overhaul modpacks may also modify PlayerExpGain for the Looting tag
       or add untagged PlayerExpGain effects that stack with this mod, altering the
       final XP. Check other mods for PlayerExpGain / tags="Looting" before combining. -->
  <append xpath="/entity_classes/entity_class[@name='playerMale']">
    <effect_group name="Reduced Looting XP">
      <passive_effect name="PlayerExpGain" operation="perc_add" value="-0.799" tags="Looting"/>
    </effect_group>
  </append>
</configs>
