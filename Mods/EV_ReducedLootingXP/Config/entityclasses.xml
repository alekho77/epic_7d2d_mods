<configs>
  <!-- Reduce XP gained from opening untouched loot containers to 20% of vanilla.
       perc_add -0.8 reduces PlayerExpGain by 80% for the Looting XP branch, leaving 20%.
       base_set must NOT be used here: base_set replaces _base_value with the literal value,
       so base_set 0.2 sets XP to a flat 0.2 which always floor-truncates to 0.
       Loot quality, search speed, loot tables, and Lucky Looter perk are completely unaffected. -->
  <append xpath="/entity_classes/entity_class[@name='playerMale']">
    <effect_group name="Reduced Looting XP">
      <passive_effect name="PlayerExpGain" operation="perc_add" value="-0.8" tags="Looting"/>
    </effect_group>
  </append>
</configs>
