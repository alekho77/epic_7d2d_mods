<?xml version="1.0" encoding="UTF-8"?>
<configs>
  <!-- Transmute Arrows and Bolts -->
  <!-- Adds recipes to convert arrows to crossbow bolts and vice versa without material loss -->
  
  <append xpath="/recipes">
    
    <!-- CONVERTING ARROWS TO CROSSBOW BOLTS -->
    
    <!-- Stone Arrow to Stone Crossbow Bolt: 1:1 conversion (1 sec - base level) -->
    <recipe name="ammoCrossbowBoltStone" count="1" craft_time="1" craft_exp_gain="0">
      <ingredient name="ammoArrowStone" count="1" />
    </recipe>
    
    <!-- Iron Arrow to Iron Crossbow Bolt: 1:1 conversion (1 sec - √2¹ ≈ 1.4 → 1) -->
    <recipe name="ammoCrossbowBoltIron" count="1" craft_time="1" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoArrowIron" count="1" />
    </recipe>
    
    <!-- Steel AP Arrow to Steel AP Crossbow Bolt: 1:1 conversion (2 sec - √2² = 2) -->
    <recipe name="ammoCrossbowBoltSteelAP" count="1" craft_time="2" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoArrowSteelAP" count="1" />
    </recipe>
    
    <!-- Flaming Arrow to Flaming Crossbow Bolt: 1:1 conversion (3 sec - √2³ ≈ 2.8 → 3) -->
    <recipe name="ammoCrossbowBoltFlaming" count="1" craft_time="3" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoArrowFlaming" count="1" />
    </recipe>
    
    <!-- Exploding Arrow to Exploding Crossbow Bolt: 1:1 conversion (4 sec - √2⁴ = 4) -->
    <recipe name="ammoCrossbowBoltExploding" count="1" craft_time="4" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoArrowExploding" count="1" />
    </recipe>
    
    <!-- CONVERTING CROSSBOW BOLTS TO ARROWS -->
    
    <!-- Stone Crossbow Bolt to Stone Arrow: 1:1 conversion (1 sec - base level) -->
    <recipe name="ammoArrowStone" count="1" craft_time="1" craft_exp_gain="0">
      <ingredient name="ammoCrossbowBoltStone" count="1" />
    </recipe>
    
    <!-- Iron Crossbow Bolt to Iron Arrow: 1:1 conversion (1 sec - √2¹ ≈ 1.4 → 1) -->
    <recipe name="ammoArrowIron" count="1" craft_time="1" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoCrossbowBoltIron" count="1" />
    </recipe>
    
    <!-- Steel AP Crossbow Bolt to Steel AP Arrow: 1:1 conversion (2 sec - √2² = 2) -->
    <recipe name="ammoArrowSteelAP" count="1" craft_time="2" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoCrossbowBoltSteelAP" count="1" />
    </recipe>
    
    <!-- Flaming Crossbow Bolt to Flaming Arrow: 1:1 conversion (3 sec - √2³ ≈ 2.8 → 3) -->
    <recipe name="ammoArrowFlaming" count="1" craft_time="3" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoCrossbowBoltFlaming" count="1" />
    </recipe>
    
    <!-- Exploding Crossbow Bolt to Exploding Arrow: 1:1 conversion (4 sec - √2⁴ = 4) -->
    <recipe name="ammoArrowExploding" count="1" craft_time="4" craft_exp_gain="0" craft_area="workbench">
      <ingredient name="ammoCrossbowBoltExploding" count="1" />
    </recipe>
    
    <!-- DISASSEMBLED AMMO BUNDLES -->
    <!-- Bundles crafted from 30 arrows/bolts; requires workbench + full Hunting Journal series -->
    
    <!-- Stone Arrow Bundle (craft_time=240, same as ammoBundleArrowStone) -->
    <recipe name="evArrowStonePartsBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoArrowStone" count="30" />
    </recipe>
    
    <!-- Iron Arrow Bundle (craft_time=240, same as ammoBundleArrowIron) -->
    <recipe name="evArrowIronPartsBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoArrowIron" count="30" />
    </recipe>
    
    <!-- Steel AP Arrow Bundle (craft_time=240, same as ammoBundleArrowSteelAP) -->
    <recipe name="evArrowSteelAPPartsBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoArrowSteelAP" count="30" />
    </recipe>
    
    <!-- Flaming Arrow Bundle (craft_time=360, same as ammoBundleArrowFlaming) -->
    <recipe name="evArrowFlamingPartsBundle" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoArrowFlaming" count="30" />
    </recipe>
    
    <!-- Exploding Arrow Bundle (craft_time=360, same as ammoBundleArrowExploding) -->
    <recipe name="evArrowExplodingPartsBundle" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoArrowExploding" count="30" />
    </recipe>
    
    <!-- Stone Bolt Bundle (craft_time=240, same as ammoBundleCrossbowBoltStone) -->
    <recipe name="evCrossbowBoltStonePartsBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoCrossbowBoltStone" count="30" />
    </recipe>
    
    <!-- Iron Bolt Bundle (craft_time=240, same as ammoBundleCrossbowBoltIron) -->
    <recipe name="evCrossbowBoltIronPartsBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoCrossbowBoltIron" count="30" />
    </recipe>
    
    <!-- Steel AP Bolt Bundle (craft_time=240, same as ammoBundleCrossbowBoltSteelAP) -->
    <recipe name="evCrossbowBoltSteelAPPartsBundle" count="1" craft_time="240" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoCrossbowBoltSteelAP" count="30" />
    </recipe>
    
    <!-- Flaming Bolt Bundle (craft_time=360, same as ammoBundleCrossbowBoltFlaming) -->
    <recipe name="evCrossbowBoltFlamingPartsBundle" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoCrossbowBoltFlaming" count="30" />
    </recipe>
    
    <!-- Exploding Bolt Bundle (craft_time=360, same as ammoBundleCrossbowBoltExploding) -->
    <recipe name="evCrossbowBoltExplodingPartsBundle" count="1" craft_time="360" craft_area="workbench" tags="learnable,workbenchCrafting">
      <ingredient name="ammoCrossbowBoltExploding" count="30" />
    </recipe>
    
  </append>
  
</configs>
