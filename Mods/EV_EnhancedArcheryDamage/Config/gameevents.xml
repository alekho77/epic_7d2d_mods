<?xml version="1.0" encoding="UTF-8"?>
<config>
  <!-- Ammo refund events used by arrow/bolt projectile impact triggers. -->
  <append xpath="/gameevents">

    <action_sequence name="evEadRefund_ammoArrowStone">
      <property name="allow_user_trigger" value="false"/>
      <property name="action_type" value="Game"/>
      <action class="AddItems">
        <property name="added_items" value="ammoArrowStone"/>
        <property name="added_item_counts" value="1"/>
      </action>
    </action_sequence>

