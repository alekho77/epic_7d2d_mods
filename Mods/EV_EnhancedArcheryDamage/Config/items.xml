      <property class="Action0">
        <property name="Create_item" value="resourceArrowHeadSteelAP,resourceScrapPolymers,resourceGunPowder,resourcePaper,resourceYuccaFibers"/>
        <property name="Create_item_count" value="75,150,450,75,75"/>
