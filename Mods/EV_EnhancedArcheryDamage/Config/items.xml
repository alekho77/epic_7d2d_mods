  <!-- === ARCHERY AMMO REFUND ON PROJECTILE IMPACT === -->
  <!-- These triggers refund one matching arrow/bolt after projectile impact.
       This is XML-only refund behavior, not true pre-shot ammo preservation. -->

  <append xpath="//item[@name='ammoArrowStone']/effect_group[@name='ammoArrowStone']">
    <triggered_effect trigger="onProjectileImpact" action="CallGameEvent" target="self" event="evEadRefund_ammoArrowStone">
      <requirement name="ProgressionLevel" progression_name="perkArchery" operation="Equals" value="1"/>
      <requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LTE" value="10"/>
    </triggered_effect>
    <triggered_effect trigger="onProjectileImpact" action="CallGameEvent" target="self" event="evEadRefund_ammoArrowStone">
      <requirement name="ProgressionLevel" progression_name="perkArchery" operation="Equals" value="2"/>
      <requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LTE" value="20"/>
    </triggered_effect>
    <triggered_effect trigger="onProjectileImpact" action="CallGameEvent" target="self" event="evEadRefund_ammoArrowStone">
      <requirement name="ProgressionLevel" progression_name="perkArchery" operation="Equals" value="3"/>
      <requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LTE" value="30"/>
    </triggered_effect>
    <triggered_effect trigger="onProjectileImpact" action="CallGameEvent" target="self" event="evEadRefund_ammoArrowStone">
      <requirement name="ProgressionLevel" progression_name="perkArchery" operation="Equals" value="4"/>
      <requirement name="RandomRoll" seed_type="Random" min_max="0,100" operation="LTE" value="40"/>
    </triggered_effect>
    <triggered_effect trigger="onProjectileImpact" action="CallGameEvent" target="self" event="evEadRefund_ammoArrowStone">
