<configs>

  <!-- ============================================================
       EV_LootBox — Loot Box item
       Uses OpenLootBundle to open a loot window whose contents
       are generated from evLootBoxRewards in loot.xml.
  ============================================================ -->

  <append xpath="/items">

    <item name="evLootBox">
      <property name="Extends"         value="questRewardBundleMaster"/>
      <property name="CreativeMode"    value="Player"/>
      <property name="CustomIcon"      value="block_missing"/>
      <property name="CustomIconTint"  value="FFFFFF"/>
      <property name="ItemTypeIcon"    value="bundle"/>
      <property name="DescriptionKey"  value="evLootBoxDesc"/>
      <property class="Action0">
        <property name="Class"       value="OpenLootBundle"/>
        <property name="Delay"       value="0"/>
        <property name="Sound_start" value="close_garbage"/>
        <property name="LootList"    value="evLootBoxRewards"/>
      </property>
    </item>

    <item name="evLootBoxGoodWeaponBundle">
      <property name="Extends"         value="questRewardBundleMaster"/>
      <property name="CreativeMode"    value="Player"/>
      <property name="CustomIcon"      value="bundleRifle"/>
      <property name="CustomIconTint"  value="FFCC00"/>
      <property name="ItemTypeIcon"    value="bundle"/>
      <property name="DescriptionKey"  value="evLootBoxGoodWeaponBundleDesc"/>
      <property class="Action0">
        <property name="Random_item" value="gunMGT2TacticalAR,meleeWpnBladeT3Machete,meleeWpnSpearT3SteelSpear,meleeWpnBatonT2StunBaton,gunHandgunT2Magnum44,gunShotgunT2PumpShotgun,gunRifleT2LeverActionRifle,gunMGT1AK47,gunBowT1IronCrossbow,meleeWpnSpearT1IronSpear,meleeWpnClubT1BaseballBat,meleeWpnBladeT1HuntingKnife,meleeWpnSledgeT1IronSledgehammer,meleeWpnKnucklesT1IronKnuckles"/>
        <property name="Random_item_count" value="2,2,2,2,6,6,6,6,6,6,6,6,6,6"/>
      </property>
    </item>

    <item name="evLootBoxValuableWeaponBundle">
      <property name="Extends"         value="questRewardBundleMaster"/>
      <property name="CreativeMode"    value="Player"/>
      <property name="CustomIcon"      value="bundleRifle"/>
      <property name="CustomIconTint"  value="FF4444"/>
      <property name="ItemTypeIcon"    value="bundle"/>
      <property name="DescriptionKey"  value="evLootBoxValuableWeaponBundleDesc"/>
      <property class="Action0">
        <property name="Random_item" value="gunHandgunT3SMG5,gunHandgunT3DesertVulture,gunShotgunT3AutoShotgun,gunRifleT3SniperRifle,gunMGT2TacticalAR,gunMGT3M60,gunBowT3CompoundBow,gunBowT3CompoundCrossbow,meleeWpnSpearT3SteelSpear,meleeWpnBladeT3Machete,meleeWpnClubT3SteelClub,meleeWpnBatonT2StunBaton,meleeWpnSledgeT3SteelSledgehammer,meleeWpnKnucklesT3SteelKnuckles"/>
        <property name="Random_item_count" value="6,6,6,6,6,6,6,6,6,6,6,6,6,6"/>
      </property>
    </item>

  </append>

</configs>
