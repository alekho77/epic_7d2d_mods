<configs>

  <!-- ============================================================
       EV_LootBox — Loot Box
      Reward-category selector: exactly one category is chosen.
        75% → Simple   (basic supplies)
        20% → Good     (better consumables)
         5% → Valuable (rare support items)
      Each reward-category pool uses count="all" so every base item in the
      selected category is guaranteed to drop.
      The selected category also rolls a 30% chance to add one matching weapon.
  ============================================================ -->

  <!-- Append all groups and the container in one block.
    Referenced lootgroups still need to be defined before use. -->
  <append xpath="/lootcontainers">

    <!-- *** evLootBoxFoodSimple — one random simple food item
         Very basic canned goods: larger count (3–5)
         Decent canned meats/fish: medium count (2–4)
         Cooked foods:             smaller count (1–3) -->
    <lootgroup name="evLootBoxFoodSimple" count="1">
      <!-- very basic canned goods -->
      <item name="foodCanPeas"      count="3,5"/>
      <item name="foodCanSoup"      count="3,5"/>
      <item name="foodCanSham"      count="3,5"/>
      <item name="foodCanChicken"   count="3,5"/>
      <!-- decent canned goods -->
      <item name="foodCanChili"     count="2,4"/>
      <item name="foodCanBeef"      count="2,4"/>
      <item name="foodCanTuna"      count="2,4"/>
      <item name="foodCanPasta"     count="2,4"/>
      <!-- cooked foods -->
      <item name="foodCornBread"    count="1,3"/>
      <item name="foodGrilledMeat"  count="1,3"/>
      <item name="foodEggBoiled"    count="1,3"/>
      <item name="foodBakedPotato"  count="1,3"/>
    </lootgroup>

    <!-- *** evLootBoxDrinkSimple — one random simple drink
         Boiled water: medium count (2–4)
         Yucca juice:  medium count (1–3)
         Tea / beer:   smallest count (1–2) -->
    <lootgroup name="evLootBoxDrinkSimple" count="1">
      <item name="drinkJarBoiledWater"  count="2,4"/>
      <item name="drinkJarYuccaJuice"   count="1,3"/>
      <item name="drinkJarGoldenRodTea" count="1,2"/>
      <item name="drinkJarBeer"         count="1,2"/>
    </lootgroup>

    <!-- *** evLootBoxMedSimple — one random basic medical item
         Most basic (bandage, aloe):   larger count (3–5 / 2–4)
         Better bandage:               medium count (2–4)
         Drugs (vitamins, painkillers): smaller count (1–3) -->
    <lootgroup name="evLootBoxMedSimple" count="1">
      <!-- very basic -->
      <item name="medicalBandage"          count="3,5"/>
      <item name="medicalAloeCream"        count="2,4"/>
      <!-- standard first-aid -->
      <item name="medicalFirstAidBandage"  count="2,4"/>
      <!-- drugs -->
      <item name="drugVitamins"            count="1,3"/>
      <item name="drugPainkillers"         count="1,3"/>
    </lootgroup>

    <!-- *** Optional category-matched weapon bonus groups
         In-game item quality (Q1-Q6) is controlled by loot_quality_template. -->
    <lootgroup name="evLootBoxWeaponsSimpleQ3" count="1" loot_quality_template="qualTwitchT3Template">
      <item name="gunMGT1AK47"/>
      <item name="meleeWpnSpearT1IronSpear"/>
      <item name="meleeWpnBladeT1HuntingKnife"/>
      <item name="meleeWpnClubT1BaseballBat"/>
      <item name="meleeWpnSledgeT1IronSledgehammer"/>
    </lootgroup>

    <lootgroup name="evLootBoxWeaponsSimpleQ6" count="1" loot_quality_template="qualTwitchT6Template">
      <item name="gunHandgunT1Pistol"/>
      <item name="gunShotgunT1DoubleBarrel"/>
      <item name="gunRifleT1HuntingRifle"/>
      <item name="gunBowT1WoodenBow"/>
      <item name="meleeWpnBatonT0PipeBaton"/>
      <item name="meleeWpnKnucklesT0LeatherKnuckles"/>
    </lootgroup>

    <lootgroup name="evLootBoxWeaponsSimple" count="1">
      <item group="evLootBoxWeaponsSimpleQ3" prob="5"/>
      <item group="evLootBoxWeaponsSimpleQ6" prob="6"/>
    </lootgroup>

    <lootgroup name="evLootBoxWeaponsGoodQ3" count="1" loot_quality_template="qualTwitchT3Template">
      <item name="gunMGT2TacticalAR"/>
      <item name="meleeWpnBladeT3Machete"/>
      <item name="meleeWpnSpearT3SteelSpear"/>
      <item name="meleeWpnBatonT2StunBaton"/>
    </lootgroup>

    <lootgroup name="evLootBoxWeaponsGoodQ6" count="1" loot_quality_template="qualTwitchT6Template">
      <item name="gunHandgunT2Magnum44"/>
      <item name="gunShotgunT2PumpShotgun"/>
      <item name="gunRifleT2LeverActionRifle"/>
      <item name="gunMGT1AK47"/>
      <item name="gunBowT1IronCrossbow"/>
      <item name="meleeWpnSpearT1IronSpear"/>
      <item name="meleeWpnClubT1BaseballBat"/>
      <item name="meleeWpnBladeT1HuntingKnife"/>
      <item name="meleeWpnSledgeT1IronSledgehammer"/>
      <item name="meleeWpnKnucklesT1IronKnuckles"/>
    </lootgroup>

    <lootgroup name="evLootBoxWeaponsGood" count="1">
      <item group="evLootBoxWeaponsGoodQ3" prob="4"/>
      <item group="evLootBoxWeaponsGoodQ6" prob="10"/>
    </lootgroup>

    <lootgroup name="evLootBoxWeaponsValuable" count="1" loot_quality_template="qualTwitchT6Template">
      <item name="gunHandgunT3SMG5"/>
      <item name="gunHandgunT3DesertVulture"/>
      <item name="gunShotgunT3AutoShotgun"/>
      <item name="gunRifleT3SniperRifle"/>
      <item name="gunMGT2TacticalAR"/>
      <item name="gunMGT3M60"/>
      <item name="gunBowT3CompoundBow"/>
      <item name="gunBowT3CompoundCrossbow"/>
      <item name="meleeWpnSpearT3SteelSpear"/>
      <item name="meleeWpnBladeT3Machete"/>
      <item name="meleeWpnClubT3SteelClub"/>
      <item name="meleeWpnBatonT2StunBaton"/>
      <item name="meleeWpnSledgeT3SteelSledgehammer"/>
      <item name="meleeWpnKnucklesT3SteelKnuckles"/>
    </lootgroup>

    <!-- *** evLootBoxSimplePool — 75% reward category + 30% simple weapon bonus -->
    <lootgroup name="evLootBoxSimplePool" count="all">
      <item group="evLootBoxFoodSimple"/>
      <item group="evLootBoxDrinkSimple"/>
      <item group="evLootBoxMedSimple"/>
      <item name="ammo9mmBulletBall"   count="50,100"/>
      <item group="evLootBoxWeaponsSimple" prob="0.30" force_prob="true"/>
    </lootgroup>

    <!-- *** evLootBoxGoodPool — 20% reward category + 30% good weapon bonus -->
    <lootgroup name="evLootBoxGoodPool" count="all">
      <item name="foodMeatStew"        count="1,2"/>
      <item name="medicalFirstAidKit"  count="1,2"/>
      <item name="ammo9mmBulletHP"     count="50,100"/>
      <item group="evLootBoxWeaponsGood" prob="0.30" force_prob="true"/>
    </lootgroup>

    <!-- *** evLootBoxValuablePool — 5% reward category + 30% valuable weapon bonus -->
    <lootgroup name="evLootBoxValuablePool" count="all">
      <item name="resourceRepairKit"      count="3,5"/>
      <item name="drugSteroids"           count="1,2"/>
      <item name="handgunsSkillMagazine"  count="2,3"/>
      <item group="evLootBoxWeaponsValuable" prob="0.30" force_prob="true"/>
    </lootgroup>

    <!-- *** Reward-category selector: choose exactly one category with 75/20/5 weights -->
    <lootgroup name="evLootBoxCategorySelector" count="1">
      <item group="evLootBoxSimplePool" prob="75"/>
      <item group="evLootBoxGoodPool" prob="20"/>
      <item group="evLootBoxValuablePool" prob="5"/>
    </lootgroup>

    <!-- *** Loot container opened by evLootBox -->
    <lootcontainer name="evLootBoxRewards"
                   count="1"
                   size="3,2"
                   sound_open="SupplyDrops/open_supply_crate"
                   sound_close="SupplyDrops/close_supply_crate"
                   loot_quality_template="qualBaseTemplate"
                   destroy_on_close="empty"
                   unique_item="true"
                   ignore_loot_abundance="true">
      <item group="evLootBoxCategorySelector"/>
    </lootcontainer>

  </append>

</configs>
