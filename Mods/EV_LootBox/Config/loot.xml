<configs>

  <!-- ============================================================
       EV_LootBox — Loot Box
      Reward-category selector: exactly one category is chosen.
        75% → Simple   (basic supplies)
        20% → Good     (better consumables)
         5% → Valuable (rare support items)
      Each reward-category pool uses count="all" so every base item in the
      selected category is guaranteed to drop.
      The selected category also rolls a 30% chance to add one matching weapon.
  ============================================================ -->

  <!-- Append all groups and the container in one block.
    Referenced lootgroups still need to be defined before use. -->
  <append xpath="/lootcontainers">

    <!-- *** Food groups — one random food item from the selected category -->
    <lootgroup name="evLootBoxFoodSimple" count="1">
      <item name="foodCanBeef"        count="3,5"/>
      <item name="foodCanChicken"     count="4,6"/>
      <item name="foodCanLamb"        count="3,5"/>
      <item name="foodCanCatfood"     count="4,6"/>
      <item name="foodCanDogfood"     count="1,3"/>
      <item name="foodCanChili"       count="1,3"/>
      <item name="foodCanTuna"        count="3,5"/>
      <item name="foodCanSham"        count="3,5"/>
      <item name="foodCanPasta"       count="3,5"/>
      <item name="foodCanSalmon"      count="3,5"/>
      <item name="foodCanMiso"        count="4,6"/>
      <item name="foodCanPeas"        count="3,5"/>
      <item name="foodCanPears"       count="4,6"/>
      <item name="foodCanSoup"        count="4,6"/>
      <item name="foodCanStock"       count="3,5"/>
      <item name="foodCornOnTheCob"   count="4,6"/>
      <item name="foodCornBread"      count="4,6"/>
      <item name="foodGrilledMeat"    count="4,6"/>
      <item name="foodBoiledMeat"     count="3,5"/>
      <item name="foodBakedPotato"    count="4,6"/>
      <item name="foodPumpkinBread"   count="3,5"/>
      <item name="foodEggBoiled"      count="4,6"/>
      <item name="foodBaconAndEggs"   count="2,4"/>
      <item name="foodVegetableStew"  count="1,3"/>
    </lootgroup>

    <lootgroup name="evLootBoxFoodGood" count="1">
      <item name="foodHoney"                count="1,3"/>
      <item name="foodMeatStew"             count="2,4"/>
      <item name="foodSteakAndPotato"       count="1,3"/>
      <item name="foodShamChowder"          count="1,3"/>
      <item name="foodHoboStew"             count="1,3"/>
      <item name="foodFishTacos"            count="1,3"/>
      <item name="foodChiliDog"             count="1,3"/>
      <item name="foodBlueberryPie"         count="2,4"/>
      <item name="foodPumpkinPie"           count="2,4"/>
      <item name="foodSpaghetti"            count="1,3"/>
      <item name="foodTunaFishGravyToast"   count="1,3"/>
    </lootgroup>

    <lootgroup name="evLootBoxFoodValuable" count="1">
      <item name="foodHoneyGlazedSham"  count="1,3"/>
      <item name="foodHoneyBrisket"     count="1,3"/>
      <item name="foodGumboStew"        count="2,4"/>
      <item name="foodShepardsPie"      count="1,3"/>
    </lootgroup>

    <!-- *** Drink groups — one random drink item from the selected category -->
    <lootgroup name="evLootBoxDrinkSimple" count="1">
      <item name="drinkJarYuccaJuice"   count="1,3"/>
      <item name="drinkJarGoldenRodTea" count="2,4"/>
      <item name="drinkJarCoffee"       count="1,3"/>
      <item name="drinkJarBoiledWater"  count="5,7"/>
    </lootgroup>

    <lootgroup name="evLootBoxDrinkGood" count="1">
      <item name="drinkJarPureMineralWater" count="2,4"/>
      <item name="drinkJarRedTea"           count="2,3"/>
    </lootgroup>

    <lootgroup name="evLootBoxDrinkValuable" count="1">
      <item name="drinkJarHoneyTea"          count="2,4"/>
      <item name="drinkJarBlackStrapCoffee"  count="1,3"/>
    </lootgroup>

    <!-- *** evLootBoxMedSimple — one random basic medical item
         Most basic (bandage, aloe):   larger count (3–5 / 2–4)
         Better bandage:               medium count (2–4)
         Drugs (vitamins, painkillers): smaller count (1–3) -->
    <lootgroup name="evLootBoxMedSimple" count="1">
      <!-- very basic -->
      <item name="medicalBandage"          count="3,5"/>
      <item name="medicalAloeCream"        count="2,4"/>
      <!-- standard first-aid -->
      <item name="medicalFirstAidBandage"  count="2,4"/>
      <!-- drugs -->
      <item name="drugVitamins"            count="1,3"/>
      <item name="drugPainkillers"         count="1,3"/>
    </lootgroup>

        <!-- *** Optional category-matched weapon bonus groups
          Simple, Good, and Valuable now route through dedicated weapon bundle items. -->

    <!-- *** evLootBoxSimplePool — 75% reward category + 30% simple weapon bonus -->
    <lootgroup name="evLootBoxSimplePool" count="all">
      <item group="evLootBoxFoodSimple"/>
      <item group="evLootBoxDrinkSimple"/>
      <item group="evLootBoxMedSimple"/>
      <item name="ammo9mmBulletBall"   count="50,100"/>
      <item name="evLootBoxSimpleWeaponBundle" prob="0.30" force_prob="true"/>
    </lootgroup>

    <!-- *** evLootBoxGoodPool — 20% reward category + 30% good weapon bonus -->
    <lootgroup name="evLootBoxGoodPool" count="all">
      <item group="evLootBoxFoodGood"/>
      <item group="evLootBoxDrinkGood"/>
      <item name="medicalFirstAidKit"  count="1,2"/>
      <item name="ammo9mmBulletHP"     count="50,100"/>
      <item name="evLootBoxGoodWeaponBundle" prob="0.30" force_prob="true"/>
    </lootgroup>

    <!-- *** evLootBoxValuablePool — 5% reward category + 30% valuable weapon bonus -->
    <lootgroup name="evLootBoxValuablePool" count="all">
      <item group="evLootBoxFoodValuable"/>
      <item group="evLootBoxDrinkValuable"/>
      <item name="resourceRepairKit"      count="3,5"/>
      <item name="drugSteroids"           count="1,2"/>
      <item name="handgunsSkillMagazine"  count="2,3"/>
      <item name="evLootBoxValuableWeaponBundle" prob="0.30" force_prob="true"/>
    </lootgroup>

    <!-- *** Reward-category selector: choose exactly one category with 75/20/5 weights -->
    <lootgroup name="evLootBoxCategorySelector" count="1">
      <item group="evLootBoxSimplePool" prob="75"/>
      <item group="evLootBoxGoodPool" prob="20"/>
      <item group="evLootBoxValuablePool" prob="5"/>
    </lootgroup>

    <!-- *** Loot container opened by evLootBox -->
    <lootcontainer name="evLootBoxRewards"
                   count="1"
                   size="3,2"
                   sound_open="SupplyDrops/open_supply_crate"
                   sound_close="SupplyDrops/close_supply_crate"
                   loot_quality_template="qualBaseTemplate"
                   destroy_on_close="empty"
                   unique_item="true"
                   ignore_loot_abundance="true">
      <item group="evLootBoxCategorySelector"/>
    </lootcontainer>

  </append>

</configs>
